# Copy this file to .env and fill values
POLYGON_API_KEY=your_polygon_api_key_here
# Allowed: polygon | yfinance (auto is disabled)
DIFFSTOCK_DATA_PROVIDER=polygon
# true: WS priority only during US regular session (09:30-16:00 ET); false: WS priority all day
DIFFSTOCK_WS_PRIORITY_RTH_ONLY=true

# Feature engine selection
# Allowed profiles: full | core | trend | custom
# Meaning:
# - PROFILE controls the base set.
# - INCLUDE adds exact feature names on top of the base set.
# - INCLUDE=full is a special shortcut meaning: include every available feature.
# - TARGET_FEATURE is the prediction label the model learns to forecast.
#   It must also exist inside the final selected feature set.
# Typical usage:
# - Use PROFILE=custom and set INCLUDE to an exact comma-separated feature list.
# - Use PROFILE=core/trend/full when you want a preset starting point.
# - Use EXCLUDE to remove a few features from a preset.
DIFFSTOCK_FEATURE_PROFILE=custom
# Benchmark symbol for relative/excess-return features
DIFFSTOCK_FEATURE_BENCHMARK=QQQ
# Optional group list: returns, benchmark, trend, volatility, oscillators, bollinger, volume, vwap, candles
DIFFSTOCK_FEATURE_GROUPS=
# Optional exact feature names to add/remove after profile/groups resolution
# Special value: full = include all available features
# Available default feature names:
# ret_1d, ret_3d, ret_5d, ret_10d, ret_20d
# log_return_1d, cumulative_return
# excess_ret_1d_vs_benchmark, excess_ret_3d_vs_benchmark, excess_ret_5d_vs_benchmark,
# excess_ret_10d_vs_benchmark, excess_ret_20d_vs_benchmark
# sma_5, ema_5, sma_slope_5, ema_slope_5, price_to_sma_5, price_to_ema_5
# sma_10, ema_10, sma_slope_10, ema_slope_10, price_to_sma_10, price_to_ema_10
# sma_20, ema_20, sma_slope_20, ema_slope_20, price_to_sma_20, price_to_ema_20
# sma_spread_5_20, ema_spread_12_26, macd_line, macd_signal, macd_histogram
# rolling_std_5, realized_vol_5, rolling_std_10, realized_vol_10, rolling_std_20, realized_vol_20
# atr_14, true_range, parkinson_vol_20, high_low_range_pct
# rsi_14, stochastic_k_14, stochastic_d_3, cci_20, williams_r_14
# bollinger_upper_20, bollinger_lower_20, bollinger_bandwidth_20, bollinger_percent_b_20
# volume_ma_20, volume_ratio_20, volume_zscore_20, dollar_volume, obv
# open_to_close_return, gap_return, upper_shadow_ratio, lower_shadow_ratio, close_location_value
# Default training set keeps the feature count tight while covering momentum, relative strength,
# trend, volatility, volume, and candle structure.
DIFFSTOCK_FEATURE_INCLUDE=log_return_1d,ret_5d,ret_20d,excess_ret_5d_vs_benchmark,excess_ret_20d_vs_benchmark,price_to_ema_20,macd_histogram,rolling_std_20,volume_ratio_20,close_location_value
DIFFSTOCK_FEATURE_EXCLUDE=
# Target feature used to build the training label and to decode future forecasts.
# It must be one of the selected features above. Recommended: log_return_1d.
DIFFSTOCK_TARGET_FEATURE=log_return_1d
